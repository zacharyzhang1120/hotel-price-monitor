# 默认使用 Mock 数据，适合 MVP 测试
HOST=127.0.0.1
PORT=8080
SCRAPER_MODE=mock
ENABLED_PLATFORMS=ctrip,qunar,tongcheng

# 携程真实抓取调试示例：
# SCRAPER_MODE=real
# ENABLED_PLATFORMS=ctrip
# HEADLESS=true
# SCRAPE_TIMEOUT=30000
# SCRAPE_DELAY_MIN_MS=2000
# SCRAPE_DELAY_MAX_MS=5000

# 定时任务默认关闭。需要测试时改为 true
SCHEDULER_ENABLED=false
SCRAPE_SCHEDULE_HOURS=12,18,22

# 备份保留数量
BACKUP_RETENTION_COUNT=30

# 企业微信机器人推送，默认关闭
REPORT_PUSH_ENABLED=false
# WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# WECOM_PUSH_TIMEOUT=10
